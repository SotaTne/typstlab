{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://typstlab.local/docs_parser/schema.json",
  "title": "Typst docs.json",
  "type": "array",
  "items": {
    "$ref": "#/definitions/entry"
  },
  "definitions": {
    "entry": {
      "type": "object",
      "required": ["route", "title"],
      "properties": {
        "route": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": ["string", "null"]
        },
        "part": {
          "type": ["string", "null"]
        },
        "outline": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/outlineItem"
          }
        },
        "body": {
          "$ref": "#/definitions/body"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/entry"
          }
        }
      },
      "additionalProperties": true
    },
    "outlineItem": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/outlineItem"
          }
        }
      },
      "additionalProperties": true
    },
    "body": {
      "type": "object",
      "required": ["kind", "content"],
      "properties": {
        "kind": {
          "enum": ["html", "func", "type", "category", "group", "symbols"]
        },
        "content": true
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "html"
              }
            }
          },
          "then": {
            "properties": {
              "content": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "func"
              }
            }
          },
          "then": {
            "properties": {
              "content": {
                "$ref": "#/definitions/functionContent"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "type"
              }
            }
          },
          "then": {
            "properties": {
              "content": {
                "$ref": "#/definitions/typeContent"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "category"
              }
            }
          },
          "then": {
            "properties": {
              "content": {
                "$ref": "#/definitions/categoryContent"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "group"
              }
            }
          },
          "then": {
            "properties": {
              "content": {
                "$ref": "#/definitions/groupContent"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "symbols"
              }
            }
          },
          "then": {
            "properties": {
              "content": {
                "$ref": "#/definitions/symbolsContent"
              }
            }
          }
        }
      ],
      "additionalProperties": true
    },
    "functionContent": {
      "type": "object",
      "required": ["name", "title"],
      "properties": {
        "path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "oneliner": {
          "type": ["string", "null"]
        },
        "details": true,
        "example": true,
        "params": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/paramContent"
          }
        },
        "returns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scope": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/functionContent"
          }
        },
        "element": {
          "type": "boolean"
        },
        "contextual": {
          "type": "boolean"
        },
        "self": {
          "type": "boolean"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deprecation": true
      },
      "additionalProperties": true
    },
    "paramContent": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "details": true,
        "example": true,
        "types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "default": true,
        "strings": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/stringChoice"
          }
        },
        "required": {
          "type": "boolean"
        },
        "positional": {
          "type": "boolean"
        },
        "named": {
          "type": "boolean"
        },
        "variadic": {
          "type": "boolean"
        },
        "settable": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "stringChoice": {
      "type": "object",
      "required": ["string"],
      "properties": {
        "string": {
          "type": "string"
        },
        "details": true
      },
      "additionalProperties": true
    },
    "typeContent": {
      "type": "object",
      "required": ["name", "title"],
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "oneliner": {
          "type": ["string", "null"]
        },
        "details": true,
        "constructor": {
          "anyOf": [
            {
              "$ref": "#/definitions/functionContent"
            },
            {
              "type": "null"
            }
          ]
        },
        "scope": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/functionContent"
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "categoryContent": {
      "type": "object",
      "required": ["name", "title"],
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "details": true,
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/categoryItem"
          }
        },
        "shorthands": true
      },
      "additionalProperties": true
    },
    "categoryItem": {
      "type": "object",
      "required": ["name", "route"],
      "properties": {
        "name": {
          "type": "string"
        },
        "route": {
          "type": "string"
        },
        "oneliner": {
          "type": ["string", "null"]
        },
        "code": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "groupContent": {
      "type": "object",
      "required": ["name", "title"],
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "details": true,
        "functions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/functionContent"
          }
        }
      },
      "additionalProperties": true
    },
    "symbolsContent": {
      "type": "object",
      "required": ["name", "title"],
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "details": true,
        "list": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/symbolItem"
          }
        }
      },
      "additionalProperties": true
    },
    "symbolItem": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "value": {
          "type": ["string", "null"]
        },
        "codepoint": {
          "type": ["integer", "null"]
        },
        "accent": {
          "type": "boolean"
        },
        "alternates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "markupShorthand": {
          "type": ["string", "null"]
        },
        "mathShorthand": {
          "type": ["string", "null"]
        },
        "mathClass": {
          "type": ["string", "null"]
        },
        "deprecation": true
      },
      "additionalProperties": true
    }
  }
}
